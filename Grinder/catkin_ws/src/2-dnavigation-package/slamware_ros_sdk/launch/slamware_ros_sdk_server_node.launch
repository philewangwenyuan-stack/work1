<launch>
  <!-- 定义参数 -->
  <arg name="ip_address" default="192.168.11.1" />
  <!-- base_link -> base_laser_link extrinsic. Fill these with the measured radar/lidar mount offset. -->
  <arg name="base_to_laser_x" default="0.2" />
  <arg name="base_to_laser_y" default="0.0" />
  <arg name="base_to_laser_z" default="0.0" />
  <arg name="base_to_laser_roll" default="0.0" />
  <arg name="base_to_laser_pitch" default="0.0" />
  <arg name="base_to_laser_yaw" default="0.0" />
  <arg name="slam_pose_is_laser_frame" default="true" />
  <arg name="publish_laser_pose_tf" default="false" />
  <arg name="align_map_to_initial_yaw" default="true" />
  <arg name="aligned_map_frame" default="map_aligned" />

  <!-- 主节点 -->
  <node pkg="slamware_ros_sdk" type="slamware_ros_sdk_server_node" name="slamware_ros_sdk_server_node" output="screen">
    <!-- 参数 -->
    <param name="ip_address"               value="$(arg ip_address)"/>
    <param name="angle_compensate"         value="true"/>

    <param name="map_frame"                value="map"/>
    <param name="robot_frame"              value="base_link"/>
    <param name="odom_frame"               value="odom"/>
    <param name="laser_frame"              value="base_laser_link"/>
    <param name="imu_frame"                value="base_imu_link"/>
    <param name="camera_left"              value="base_camera_left"/>
    <param name="camera_right"             value="base_camera_right"/>
    <param name="slam_pose_is_laser_frame" value="$(arg slam_pose_is_laser_frame)"/>
    <param name="publish_laser_pose_tf"    value="$(arg publish_laser_pose_tf)"/>
    <param name="align_map_to_initial_yaw" value="$(arg align_map_to_initial_yaw)"/>
    <param name="aligned_map_frame"        value="$(arg aligned_map_frame)"/>
    <param name="base_to_laser_x"          value="$(arg base_to_laser_x)"/>
    <param name="base_to_laser_y"          value="$(arg base_to_laser_y)"/>
    <param name="base_to_laser_z"          value="$(arg base_to_laser_z)"/>
    <param name="base_to_laser_roll"       value="$(arg base_to_laser_roll)"/>
    <param name="base_to_laser_pitch"      value="$(arg base_to_laser_pitch)"/>
    <param name="base_to_laser_yaw"        value="$(arg base_to_laser_yaw)"/>

    <param name="robot_pose_pub_period"    value="0.05"/>
    <param name="scan_pub_period"          value="0.1"/>
    <param name="map_pub_period"           value="0.2"/>
    <param name="imu_raw_data_period"      value="0.005"/>

    <param name="ladar_data_clockwise"     value="true"/>
    <param name="robot_pose_topic"         value="robot_pose"/>
    <!-- default to enable compressed image stream -->
    <param name="no_preview_image"         value="false"/>
    <!-- default to disable raw image stream. be careful to turn it on,make sure there is enough network bandwidth(>=300mbps)  -->
    <param name="raw_image_on"            value="false"/>

    <!-- Topic 重映射 -->
    <remap from="slamware_ros_sdk_server_node/scan"                       to="scan"/>
    <remap from="slamware_ros_sdk_server_node/odom"                       to="odom"/> 
    <remap from="slamware_ros_sdk_server_node/map"                        to="map"/>
    <remap from="map_metadata"                                            to="map_metadata"/>
  </node>
  <!-- <env name="ROS_TF_REPEATED_DATA" value="ignore" /> -->
  <!-- 静态 TF 变换 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="baselink2map" 
        args="0 0 0 0 0 0 1 map odom"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_to_laser"
        args="$(arg base_to_laser_x) $(arg base_to_laser_y) $(arg base_to_laser_z) $(arg base_to_laser_yaw) $(arg base_to_laser_pitch) $(arg base_to_laser_roll) base_link base_laser_link"/>
  <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="base_link2odom" 
        args="0 0 0 0 0 0 1 odom base_link"/> -->
  <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="laser2base" 
        args="0 0 0.0315 0 0 0 1 base_link base_laser_link"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="leftcam2base" 
        args="0.0418 0.03 0 -0.5 0.5 -0.5 0.5 base_link base_camera_left"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="rightcam2Leftcam" 
        args="0.06 0 0 0 0 0 1 base_link base_camera_right"/>
  <node pkg="tf2_ros" type="static_transform_publisher" name="imu2Leftcam" 
        args="0.03 0 0 0 0 -0.7071068 0.7071068 base_link base_imu_link"/> -->
</launch>
